{
  "name": "playwithfriends",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "tsx scripts/validate-games.ts && node scripts/generate-index.mjs && node scripts/optimize-images.mjs && ng build && node scripts/generate-sitemap.mjs",
    "validate": "tsx scripts/validate-games.ts",
    "images:optimize": "node scripts/optimize-images.mjs",
    "build:dev": "tsx scripts/validate-games.ts && ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "serve:ssr:playwithfriends": "node dist/playwithfriends/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/platform-server": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@angular/ssr": "^19.2.22",
    "@fontsource/open-sans": "^5.2.7",
    "@types/lunr": "^2.3.7",
    "express": "^4.18.2",
    "lunr": "^2.3.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.22",
    "@angular/cli": "^19.2.22",
    "@angular/compiler-cli": "^19.2.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2"
  }
}
